# Dice MCP (https://mcp.dice.com/mcp) — no credentials required

# LinkedIn MCP (linkedin-scraper-mcp) — no env vars required
# Credentials stored in ~/.linkedin-mcp/ after running:
#   uvx linkedin-scraper-mcp@latest --login

# AgentMail — required for $notify-email and $run-job-search
AGENTMAIL_API_KEY=
# Inbox identifier used as the sender (often an AgentMail address)
AGENTMAIL_INBOX_ID=
# Human recipient for job-search summaries
NOTIFY_MAIL_DESTINATION=

# Trello — reserved for the unimplemented future skills
TRELLO_API_KEY=
TRELLO_TOKEN=
